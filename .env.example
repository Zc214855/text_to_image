# 复制为 .env 后填写真实密钥。禁止将 .env 提交到版本库。

# 图片生成供应商
SILICONFLOW_API_KEY=sk-your-siliconflow-key
DASHSCOPE_API_KEY=sk-your-dashscope-key
ARK_API_KEY=your-volcengine-ark-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128

# 图片生成默认值
IMAGE_MODEL=doubao-seedream-5-0-260128
IMAGE_SIZE=1728x2304
OUTPUT_DIR=output

# LLM 供应商：siliconflow / zhipu / volcengine
LLM_PROVIDER=zhipu

# 智谱 GLM-5.1（腾讯云 Token Plan，OpenAI 兼容协议）
ZHIPU_API_KEY=sk-tp-your-zhipu-key
ZHIPU_BASE_URL=https://api.lkeap.cloud.tencent.com/plan/v3
ZHIPU_MODEL=glm-5.1

# 火山方舟 LLM；模型 ID 可替换为已开通的模型或 Endpoint ID
ARK_LLM_MODEL=doubao-seed-2-0-lite-260215

# 可选：覆盖任意供应商的默认 LLM 配置
# LLM_BASE_URL=https://your-llm-proxy/v1
# LLM_API_KEY=your-llm-key
# LLM_MODEL=your-model
