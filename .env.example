# SiliconFlow API Key (https://cloud.siliconflow.cn/account/ak)
SILICONFLOW_API_KEY=sk-your-api-key-here

# 阿里云百炼 DashScope API Key (https://bailian.console.aliyun.com/)
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# ===== LLM 配置（拆分故事场景用）=====
# 默认用 SiliconFlow 直连，如果要用 FreeLLMAPI 免费代理则配置以下三项：
# LLM_PROVIDER=freellmapi
# LLM_BASE_URL=http://localhost:3001/v1
# LLM_API_KEY=freellmapi-your-key
# LLM_MODEL=auto
